class Solution {
    int idx = 0;
    int kthsmall = 0;
    public int kthSmallest(TreeNode root, int k) {
        if(root == null);
        traverse(root,k);
        return kthsmall;
    }
    public void traverse(TreeNode node, int k){
        if(node == null) return;
        traverse(node.left,k);
        idx++;
        if(idx == k) kthsmall = node.val;
        traverse(node.right,k);
    }
}
