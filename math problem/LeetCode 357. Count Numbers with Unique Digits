Hint
Given an integer n, return the count of all numbers with unique digits, x, where 0 <= x < 10n.

 

Example 1:

Input: n = 2
Output: 91
Explanation: The answer should be the total numbers in the range of 0 ≤ x < 100, excluding 11,22,33,44,55,66,77,88,99
Example 2:

Input: n = 0
Output: 1
*/


class Solution {
    public int countNumbersWithUniqueDigits(int n) {
        if(n==0)
            return 1;
        return backTracking(new HashSet<>(), 0, n);
    }
    public int backTracking(Set<Integer> used,int length, int n)
    {
        int count = 1;
        if(length==n)
        {
            return count;
        }
        for(int digit = 0; digit<= 9 ;digit++)
        {

            if(length==0 && digit==0)
                continue;
            //{
                //count += backTracking(used,length+1,n);
            //}

            if(used.contains(digit))
                continue;
            // if
            // {
                used.add(digit);
                count += backTracking(used,length+1,n);
                used.remove(digit);
            // }
        }
        return count;
    }
}
