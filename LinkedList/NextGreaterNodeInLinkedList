Hint
You are given the head of a linked list with n nodes.

For each node in the list, find the value of the next greater node. That is, for each node, find the value of the first node that is next to it and has a strictly larger value than it.

Return an integer array answer where answer[i] is the value of the next greater node of the ith node (1-indexed). If the ith node does not have a next greater node, set answer[i] = 0.

 

Example 1:


Input: head = [2,1,5]
Output: [5,5,0]
Example 2:


Input: head = [2,7,4,3,5]
Output: [7,0,5,5,0]
 
*/



class Solution {
    public int[] nextLargerNodes(ListNode head) {
        List<Integer> list = new ArrayList<>();
        if(head == null)
        {
            return null;
        }
        else if(head.next == null)
        {
            list.add(0);
            return list.stream().mapToInt(i -> i).toArray(); 
        }
        ListNode current = head;
        ListNode temp = current;
        if(current.next == null)
            return list.stream().mapToInt(i -> i).toArray(); 
        else
            current = current.next;   
        while (temp != null) {
    // current starts from the node AFTER temp
    current = temp.next; 
    
    // Flag to check if we found a greater element
    boolean found = false;

    while (current != null) {
        if (current.val > temp.val) {
            list.add(current.val);
            found = true;
            break; // Stop looking once the first greater is found
        }
        current = current.next;
    }

    // If we finished the inner loop without finding a greater element
    if (!found) {
        list.add(0);
    }

    // Move to the next node in the list to repeat the process
    temp = temp.next;
}
        //list.add(0);
        return list.stream().mapToInt(i -> i).toArray(); 
    }
}
