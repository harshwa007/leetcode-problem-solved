        // 1st Column
        for(int i = 1; i<= l1; ++i)
        {
            dp[i][0] = dp[i-1][0] && s1.charAt(i-1) == s3.charAt(i-1); 
        }
        // 1st Row
        for(int j = 1; j<= l2; ++j)
        {
            dp[0][j] = dp[0][j-1] && s2.charAt(j-1) == s3.charAt(j-1);
        }

        for(int i = 1; i<= l1; ++i)
        {
            for(int j = 1; j<= l2; ++j)
            {
                boolean flag1 = dp[i-1][j] && s1.charAt(i-1) == s3.charAt(i+j-1);
                boolean flag2 = dp[i][j-1] && s2.charAt(j-1) == s3.charAt(i+j-1);
                dp[i][j] = flag1 || flag2;
            }
        }
        return dp[l1][l2];
    }
