class Solution {

    public boolean isInterleave(String s1, String s2, String s3) {

        int m = s1.length();
        int n = s2.length();

        // Impossible length
        if (m + n != s3.length()) {
            return false;
        }

        Boolean[][] dp = new Boolean[m + 1][n + 1];

        return solve(0, 0, s1, s2, s3, dp);
    }

    private boolean solve(
        int i,
        int j,
        String s1,
        String s2,
        String s3,
        Boolean[][] dp
    ) {

        // Reached end
        if (i == s1.length() && j == s2.length()) {
            return true;
        }

        // Already computed
        if (dp[i][j] != null) {
            return dp[i][j];
        }

        int k = i + j;

        boolean ans = false;

        // Take from s1
        if (
            i < s1.length() &&
            s1.charAt(i) == s3.charAt(k)
        ) {
            ans = solve(i + 1, j, s1, s2, s3, dp);
        }

        // Take from s2
        if (
            !ans &&
            j < s2.length() &&
            s2.charAt(j) == s3.charAt(k)
        ) {
            ans = solve(i, j + 1, s1, s2, s3, dp);
        }

        return dp[i][j] = ans;
    }
}
